<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/ivUserProfile"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/ic_menu_camera"
        app:tint="@color/tasky_blue_profile"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="&quot;Usuario&quot;"
        android:textColor="@color/tasky_body_text_black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/ivUserProfile"
        app:layout_constraintBottom_toBottomOf="@id/ivUserProfile"
        app:layout_constraintStart_toEndOf="@id/ivUserProfile" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clRequestTaskCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/shape_card_background"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/ivUserProfile"
        app:layout_constraintBottom_toTopOf="@id/clPerformTaskCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_weight="1">

        <TextView
            android:id="@+id/tvIconRequest"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/shape_circular_icon_border"
            android:gravity="center"
            android:text="?"
            android:textColor="@color/tasky_icon_border_dark"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvTitleRequest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Solicitar tarea"
            android:textColor="@color/tasky_card_border_light"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvBodyRequest"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:text="Solicita a gente por tu zona para realizar una tarea"
            android:textColor="@color/tasky_body_text_black"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvTitleRequest"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvIconRequest" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clPerformTaskCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/shape_card_background"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/clRequestTaskCard"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_weight="1">

        <TextView
            android:id="@+id/tvIconPerform"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/shape_circular_icon_border"
            android:gravity="center"
            android:text="!"
            android:textColor="@color/tasky_icon_border_dark"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvTitlePerform"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Realizar tarea"
            android:textColor="@color/tasky_card_border_light"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvBodyPerform"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:text="Realiza trabajos para personas por tu zona"
            android:textColor="@color/tasky_body_text_black"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvTitlePerform"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvIconPerform" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>